# AutoResearch Docker Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# OPENAI CONFIGURATION
# ============================================
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# ANTHROPIC CONFIGURATION
# ============================================
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-opus-4.6
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================
# CHINESE AI SERVICES
# ============================================
# Deepseek
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_MODEL=deepseek-v3
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Alibaba Qwen
QWEN_API_KEY=your_key_here
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# LOCAL LLM SERVICES
# ============================================
# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=mistral

# vLLM (local, high performance)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistral-7b

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=autoresearch
POSTGRES_PASSWORD=change_me_to_secure_password!
POSTGRES_DB=autoresearch_knowledge
DATABASE_URL=postgresql://autoresearch:change_me_to_secure_password!@postgres:5432/autoresearch_knowledge

# Redis
REDIS_URL=redis://redis:6379

# ============================================
# AUTORESEARCH CONFIGURATION
# ============================================
AGENTS_COUNT=4
GPU_ALLOCATION_STRATEGY=time-division
LOG_LEVEL=INFO
AUTORESEARCH_MODE=docker

# ============================================
# STORAGE & CACHING
# ============================================
DATA_CACHE_DIR=/root/.cache/autoresearch
RESULTS_DIR=/app/results
CHECKPOINT_DIR=/app/results/checkpoints
COLD_STORAGE_DIR=/app/results/cold-storage

# ============================================
# RESOURCE LIMITS
# ============================================
MAX_GPU_MEMORY_GB=80
MAX_API_TOKENS_PER_MIN=50000
MAX_CONCURRENT_EXPERIMENTS=4

# ============================================
# MURMUR INTEGRATION
# ============================================
MURMUR_ENDPOINT=http://murmur:3004
MURMUR_AUTO_SYNC=true
MURMUR_SYNC_FREQUENCY_MINUTES=30

# ============================================
# SPREADSHEET-MOMENT INTEGRATION
# ============================================
SPREADSHEET_ENDPOINT=http://spreadsheet-moment:5173
SPREADSHEET_API_URL=http://autoresearch:8000

# ============================================
# DEPLOYMENT TARGETS
# ============================================
# GitHub Wiki
GITHUB_REPO_URL=https://github.com/user/wiki
GITHUB_BRANCH=research-findings
GITHUB_AUTO_SYNC=true

# S3-compatible storage (for archives)
S3_ENDPOINT=https://r2.example.com
S3_BUCKET=autoresearch-results
S3_ACCESS_KEY=your_key_here
S3_SECRET_KEY=your_secret_here
S3_REGION=auto

# ============================================
# RETENTION POLICIES
# ============================================
HOT_STORAGE_DAYS=1
WARM_STORAGE_DAYS=30
COLD_STORAGE_DAYS=180
COMPRESS_AFTER_DAYS=14

# ============================================
# RESEARCH CONFIGURATION
# ============================================
RESEARCH_TEMPLATE=technical_wiki
RESEARCH_FOCUS=Machine Learning and Neural Network Optimization
INSTITUTION_NAME=Independent Researcher
RESEARCHER_NAME=Your Name Here
RESEARCHER_EMAIL=your.email@example.com

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
PROMETHEUS_ENABLED=false
TENSORBOARD_ENABLED=true
TENSORBOARD_PORT=6006
DEBUG_MODE=false

# ============================================
# NOTES
# ============================================
# 1. Change POSTGRES_PASSWORD to a secure value!
# 2. Add your API keys from:
#    - OpenAI: https://platform.openai.com/api-keys
#    - Anthropic: https://console.anthropic.com/
#    - Deepseek: https://platform.deepseek.com/
#    - Qwen: https://dashscope.aliyuncs.com/
# 3. For local models, ensure Ollama or vLLM is running
# 4. S3 keys are optional (only needed for archive storage)
# 5. GitHub token is optional (only needed for wiki sync)
# 6. Uncomment services you want to use
