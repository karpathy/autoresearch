# ============================================================
# Python Standard Ignores
# ============================================================
__pycache__/
*.py[oc]
*.pyc
.venv/
build/
dist/
wheels/
*.egg-info/

# ============================================================
# Research Workflow Runtime Artifacts
# ============================================================
# Per-run experiment outputs (not committed)
**/results/results.tsv
**/results/musings.md
**/run.log
**/outputs/
workflows/exec-summarizer/threads/*/jobs/

# Root-level runtime artifacts
results.tsv
musings.md
run.log
progress.db
*.png

# ============================================================
# IDE and Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# Operating System
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Data and Cache
# ============================================================
# Local data directories (datasets should be downloaded/cached per machine)
data/
**/data/

# ============================================================
# Agent Session Files
# ============================================================
# Agent prompt files (generated per-session by launchers)
CLAUDE.md

