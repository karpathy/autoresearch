{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python *)",
      "Bash(uv run *)",
      "Bash(python3:*)",
      "Edit(~/.cache/autotrader/**)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Read(**/.zshrc)",
      "Read(**/.bash_profile)",
      "Read(**/.bashrc)",
      "Read(**/.profile)",
      "Read(**/.cache/autotrader/eval_count)",
      "Read(**/core/**)",
      "Read(**/prepare.py)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowLocalBinding": false
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $(git rev-parse --show-toplevel)/.claude/hooks/protect_holdout.py"
          }
        ]
      }
    ]
  }
}